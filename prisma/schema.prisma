generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model DailyStockSnapshot {
  id          String   @id @default(cuid())
  date        String   @unique // "2026-07-08" format
  stockCount  Int
  stocksJson  String   // JSON array of {name, ticker, close, change, volGainPct, isPositive}
  createdAt   DateTime @default(now())
}