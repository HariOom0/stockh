generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DailyStockSnapshot {
  id          String   @id @default(cuid())
  date        String   @unique
  stockCount  Int
  stocksJson  String
  createdAt   DateTime @default(now())
}